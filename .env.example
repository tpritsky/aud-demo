# Copy to `.env.local` for local dev (that file stays gitignored).
# Production: set the same keys in Vercel → Settings → Environment Variables.

# -----------------------------------------------------------------------------
# ElevenLabs webhook signing secret (HMAC)
# From: ElevenLabs → Webhooks → your endpoint → signing secret. Paste below (no quotes).
# Must match `ELEVENLABS_WEBHOOK_SECRET` in Vercel or POST /api/calls returns 401.
# -----------------------------------------------------------------------------
ELEVENLABS_WEBHOOK_SECRET=

# Full template with all optional vars: scripts/env.placeholders.env
