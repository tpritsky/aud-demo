# Copy this file to scripts/env.vercel.filled and fill values (that copy is gitignored).
# Or fill here and use File → Save As → scripts/env.vercel.filled

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Or use dashboard “publishable default” name (same value):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=...
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- App URL (no trailing slash) ---
NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app

# --- ElevenLabs ---
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_WEBHOOK_SECRET=YOUR_ELEVENLABS_WEBHOOK_SIGNING_SECRET
# Optional: pin ConvAI workspace tool id for send_follow_up_now (otherwise created/looked up on push).
# ELEVENLABS_SEND_FOLLOWUP_TOOL_ID=

# --- Resend (team invites, test message, live + post-call follow-up email) ---
RESEND_API_KEY=YOUR_RESEND_API_KEY
# From address is support@vocalis.team (lib/email/resend-from.ts); domain must be verified in Resend.

# --- Anthropic (call AI) ---
CALUDE_CALL_SUMMARY_KEY1=YOUR_ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# ANTHROPIC_CALL_MODEL=claude-sonnet-4-20250514

# --- Scheduled outbound cron (optional; Vercel Cron hits /api/cron/scheduled-outbound) ---
# CRON_SECRET=long-random-string

# --- QStash (optional; one-shot scheduled outbound dispatch to /api/internal/dispatch-scheduled-outbound) ---
# Requires QSTASH_TOKEN + NEXT_PUBLIC_APP_URL (or VERCEL_URL) + CRON_SECRET (same bearer the internal route expects).
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# CALL_AI_PROCESS_SECRET=

# --- Twilio (optional: Settings → Agent → test SMS) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_SMS_FROM=+15551234567
# TWILIO_AUTH_TOKEN=
# Or: TWILIO_API_KEY_SID= + TWILIO_API_KEY_SECRET= (with Account SID above)

# --- Usually omit on Vercel ---
# DATABASE_URL=
# DIRECT_URL=
