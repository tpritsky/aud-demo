# =============================================================================
# Template only — copy, fill in values, then:
#   • Vercel: Settings → Environment Variables → bulk import / paste, OR
#   • Local: merge into .env.local (do not commit filled file)
# =============================================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Same key as dashboard “anon” / “publishable default” (either name is OK in this app)
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- App URL (production: your Vercel domain, no trailing slash) ---
NEXT_PUBLIC_APP_URL=https://YOUR_PROJECT.vercel.app

# --- ElevenLabs ---
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
# Webhooks → endpoint signing secret (paste here and in Vercel; same value as ElevenLabs shows)
ELEVENLABS_WEBHOOK_SECRET=

# --- Resend (team invites + Settings → Agent → test email + mid-call follow-up email) ---
RESEND_API_KEY=YOUR_RESEND_API_KEY
# From: support@vocalis.team (see lib/email/resend-from.ts); verify domain in Resend.
# Mid-call sends: ElevenLabs tool POSTs to ${NEXT_PUBLIC_APP_URL}/api/convai/send-follow-up — use a public https URL
# (Vercel production or a tunnel like ngrok). ElevenLabs cannot reach localhost. After setting URL, sync/push the agent
# so `send_follow_up_now` is attached; templates need email (or both) in delivery + send_email in the tool call.

# --- Anthropic (call transcript AI) — use one or both names below ---
CALUDE_CALL_SUMMARY_KEY1=YOUR_ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# Optional model override
# ANTHROPIC_CALL_MODEL=claude-sonnet-4-20250514
# Optional: super-admin “prefill business from URL” (default = ANTHROPIC_CALL_MODEL / Haiku)
# ANTHROPIC_BUSINESS_URL_MODEL=claude-haiku-4-5

# --- Tavily (super-admin: extract website text before Claude prefill) ---
# TAVILY_API_KEY=tvly-YOUR_TAVILY_KEY

# --- Upstash QStash (async /api/internal/process-call-ai) — optional ---
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# Optional bearer for manual/cron hits to the worker without QStash
# CALL_AI_PROCESS_SECRET=

# --- Twilio (Settings → Agent → test SMS; optional) ---
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# E.164 sender for test SMS (can differ from the ConvAI / receptionist line)
# TWILIO_SMS_FROM=+15551234567
# Auth: either main auth token OR API key (both work with the Messages API):
# TWILIO_AUTH_TOKEN=your_auth_token
# Optional if you already set Supabase Auth SMS Twilio token to the same value:
# SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
# Or API key (username = key SID, password = secret; Account SID still required in URL):
# TWILIO_API_KEY_SID=SKxxxxxxxx
# TWILIO_API_KEY_SECRET=
# Optional aliases for “From” if TWILIO_SMS_FROM is unset:
# TWILIO_PHONE_NUMBER=
# TWILIO_FROM_NUMBER=

# --- Local / migration scripts only (usually omit from Vercel) ---
# DATABASE_URL=postgresql://...
# DIRECT_URL=postgresql://...
